# Copy to .env and fill in. The library reads from environment variables.
# .env is gitignored.

# Required for synthesize() and compare() (frontier model calls):
ANTHROPIC_API_KEY=sk-ant-...

# Optional — Ollama endpoint and model (defaults shown):
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:26b

# Optional — override frontier model:
# HARNESS_CLAUDE_MODEL=claude-sonnet-4-5

# Optional — NCBI API key for higher PubMed rate limit (10 req/s vs 3):
# NCBI_API_KEY=...
